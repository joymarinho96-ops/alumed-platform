{
  "version": 2,
  "framework": null,
  "builds": [
    {
      "src": "alumed/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    },
    {
      "src": "staticfiles/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "alumed/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "alumed.settings",
    "PYTHONPATH": "."
  }
}
