# ═══════════════════════════════════════════════
#  ALUMED OS — .gitignore (Segurança Reforçada)
#  NUNCA remova itens desta lista
# ═══════════════════════════════════════════════

# ── Django ───────────────────────────────────────
*.log
*.pot
*.pyc
__pycache__/
local_settings.py
settings_local.py
db.sqlite3
db.sqlite3-journal
media/
settings.py
!alumed/settings.py

# ── Ambientes Virtuais ────────────────────────────
venv/
env/
.venv/

# ── Variáveis de Ambiente (NUNCA subir) ──────────
.env
.env.*
*.env
.env.local
.env.production
.env.staging

# ── IDEs ─────────────────────────────────────────
.vscode/
.idea/

# ── Credenciais Google Cloud (NUNCA subir) ────────
credentials.json
token.json
gcs_credentials.json
gcs_credentials2.json
alumed/gcs_credentials.json
alumed/gcs_credentials2.json
service_account*.json
*-service-account*.json

# ── Chaves e Tokens (NUNCA subir) ─────────────────
*.pem
*.key
*.p12
*.p8
*.pfx
*_rsa
*_rsa.pub
secrets.json
secret*.json

# ── Mac/Windows ───────────────────────────────────
.DS_Store
Thumbs.db

# ── Arquivos temporários / logs / scraping ────────
tmp-*
@ + *
tmp_library_server.py
apply_cors.py
check_sites.py
conecta-biblioteca-source.html
scratch/

# ── Imagens e HTMLs gerados (não templates) ───────
*.png
netlify_build/*.html
netlify_build/**/*.html

# ── JSONs (exceto configs necessários) ────────────
*.json
!requirements.txt
!wix.config.json
!wix.config.json.backup
!cors.json

.vercel
